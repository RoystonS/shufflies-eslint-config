{
  "name": "@shufflies/eslint-config",
  "version": "0.0.0-semantically-released",
  "description": "",
  "type": "module",
  "exports": {
    ".": {
      "import": "./lib/esm/index.js",
      "require": "./lib/cjs/index.js",
      "types": "./lib/types/index.d.ts"
    }
  },
  "module": "./lib/esm/index.js",
  "main": "./lib/cjs/index.js",
  "files": [
    "lib"
  ],
  "scripts": {
    "prepare": "husky",
    "clean": "rimraf lib",
    "test": "eslint test --config test/eslint.config.mjs --report-unused-disable-directives",
    "build:types": "tsc --declaration --emitDeclarationOnly --outDir lib/types -p src",
    "build:cjs": "tsc --module commonjs --outDir lib/cjs -p src",
    "build:esm": "tsc --module nodenext --outDir lib/esm -p src",
    "build": "concurrently -n cjs,esm,types \"npm:build:cjs\" \"npm:build:esm\" \"npm:build:types\""
  },
  "keywords": [
    "eslint",
    "eslint-config"
  ],
  "author": "Royston Shufflebotham",
  "license": "MIT",
  "packageManager": "npm@11.12.1",
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RoystonS/shufflies-eslint-config.git"
  },
  "peerDependencies": {
    "eslint": "^10.1.0"
  },
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "13.1.5",
    "@types/node": "^25.5.0",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "rimraf": "^6.1.3",
    "semantic-release": "25.0.3"
  },
  "dependencies": {
    "@eslint/compat": "^2.0.3",
    "@eslint/js": "^10.0.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unicorn": "^64.0.0",
    "typescript-eslint": "^8.58.0"
  },
  "overrides": {
    "brace-expansion": "^5.0.5",
    "picomatch": "^4.0.4"
  }
}
